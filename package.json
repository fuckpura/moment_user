{
  "name": "user-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3300",
    "build": "vite build && tsc --noEmit",
    "build:deploy": "vite build && tsc --noEmit && bun scripts/write-runtime-config.mjs dist/config.js --app user",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.1.7"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.1"
}
